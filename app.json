{
  "expo": {
    "name": "CryptoComp",
    "slug": "cryptocomp",
    "version": "1.3.2",
    "scheme": "cryptocomp",
    "orientation": "portrait",
    "icon": "./assets/app-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/e7abe187-7396-439e-96ec-aa7832f23d46",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/app-icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "bundleIdentifier": "com.simpledesignllc.cryptocomp",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "CryptoComp lets you choose a photo from your library to use as your profile avatar. Selected photos are uploaded only to your own account and are never shared without your action.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.simpledesignllc.cryptocomp",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications",
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "e7abe187-7396-439e-96ec-aa7832f23d46"
      }
    },
    "owner": "simple-design"
  }
}
