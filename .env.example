# Example client env vars. Copy the ones you need into `.env.local` (gitignored).
# EXPO_PUBLIC_* vars are inlined into the JS bundle at BUILD time — set them
# before `expo start` / `eas build`, not at runtime, and rebuild to change them.

# CoinGecko Demo API key — read by src/services/priceService.ts.
EXPO_PUBLIC_COINGECKO_API_KEY=

# --- Stripe payouts (TEST mode) ---
# Turn the real-money payout surfaces on for THIS build only. Production builds
# leave this unset → PAYOUTS_ENABLED / CONTEST_CASH_PRIZES stay false
# (see src/constants/featureFlags.ts). Preview builds set it via eas.json.
EXPO_PUBLIC_PAYOUTS_ENABLED=true
# Stripe publishable key (TEST). Safe to expose — it's the publishable key, not
# the secret. The secret (sk_test_…) lives in the Amplify backend secret
# STRIPE_SECRET_KEY, never in the client.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
